# Run dbt models in the 'ecommerce_dbt' project using Docker Compose

docker compose run --rm dbt run --project-dir ecommerce_dbt

# ────────────────────────────────────────────────────────────────
# docker compose run       : Start a one-off container from the 'dbt' service
# --rm                     : Automatically remove the container when the command finishes
# dbt run                  : Execute all SQL models in your dbt project
# --project-dir ecommerce_dbt : Specify the folder where your dbt project is located
#
# Effect:
# - dbt reads all models from ecommerce_dbt/models/
# - Compiles them into SQL
# - Runs the SQL on your target database (Postgres)
# - Creates or updates tables/views in the database
# - Cleans up the container after completion
