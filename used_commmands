#dbt seed is a dbt command that loads CSV files from your project into your database.
docker compose run --rm dbt seed --project-dir ecommerce_dbt
dbt will:

# Read the CSV
# Create a table in your database (usually your dev schema)
# The table name matches the CSV file name (ecommerce_sales)
# Now this table is managed by dbt, not manually created

